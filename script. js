// Конфігурація
const DEFAULT_FROM = [49.8419, 24.0315]; // Ратуша
const DEFAULT_TO = [49.8130, 23.9560];   // Аеропорт

let map = L.map('map', { zoomControl: false }).setView(DEFAULT_FROM, 14);
L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png').addTo(map);

const TIME_EPOCHS = {
    medieval: { name: "Середньовіччя", filter: "sepia(0.5) grayscale(0.3) contrast(1.1)", multiplier: 5.0 },
    austria: { name: "Австрійський Львів", filter: "sepia(0.8) contrast(1.2)", multiplier: 2.5 },
    modern: { name: "Сучасність", filter: "none", multiplier: 1.0 }
};

let currentEpoch = 'modern';
let activeMarkers = [];

// === Машина Часу ===
function handleSlider(value) {
    const epochs = ['medieval', 'austria', 'modern'];
    setEpoch(epochs[value]);
}

function setEpoch(epochId) {
    currentEpoch = epochId;
    const epoch = TIME_EPOCHS[epochId];
    
    // Візуал
    document.getElementById('map').style.filter = epoch.filter;
    document.getElementById('currentEpochDisplay').textContent = `Епоха: ${epoch.name}`;
    
    // Оновлення маркерів
    updateHistoricalMarkers(epochId);
}

function updateHistoricalMarkers(epochId) {
    activeMarkers.forEach(m => map.removeLayer(m));
    activeMarkers = [];
    
    const data = (epochId === 'modern') ? [] : [
        { coords: [49.8400, 24.0290], name: "Кінний екіпаж", icon: "horse" },
        { coords: [49.8425, 24.0320], name: "Варта", icon: "shield" }
    ];

    data.forEach(item => {
        const icon = L.divIcon({
            html: `<div class="hist-marker" style="background:${epochId==='medieval'?'#8b4513':'#4682b4'}"><i class="fas fa-${item.icon}"></i></div>`,
            className: 'custom-icon'
        });
        const m = L.marker(item.coords, {icon}).addTo(map).bindPopup(item.name);
        activeMarkers.push(m);
    });
}

// === Геокодування та Пошук ===
async function handleInput(e, type) {
    const val = e.target.value;
    if (val.length < 3) return;

    const response = await fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(val + ', Львів')}&limit=3`);
    const data = await response.json();
    
    const sugBox = document.getElementById(`${type}Suggestions`);
    sugBox.innerHTML = data.map(p => `
        <div class="suggestion-item" onclick="selectPlace(${p.lat}, ${p.lon}, '${p.display_name}', '${type}')">
            ${p.display_name.split(',')[0]}
        </div>
    `).join('');
}

function selectPlace(lat, lon, name, type) {
    document.getElementById(`${type}Input`).value = name.split(',')[0];
    document.getElementById(`${type}Suggestions`).innerHTML = '';
    map.panTo([lat, lon]);
}

// === Оплата ===
function openPayment(routeName, price) {
    document.getElementById('payRouteName').textContent = routeName;
    document.getElementById('payAmount').textContent = `₴${price}`;
    document.getElementById('paymentModal').classList.add('active');
}

function processPayment(method) {
    // Імітація запиту
    setTimeout(() => {
        document.getElementById('paymentInitial').style.display = 'none';
        document.getElementById('paymentSuccess').style.display = 'block';
    }, 1500);
}

function closePayment() {
    document.getElementById('paymentModal').classList.remove('active');
}
