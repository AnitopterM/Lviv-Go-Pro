:root {
    --bg: #0f172a;
    --primary: #6366f1;
    --success: #10b981;
    --glass: rgba(15, 23, 42, 0.8);
}

body, html { margin: 0; padding: 0; height: 100%; font-family: 'Segoe UI', sans-serif; background: var(--bg); overflow: hidden; }

#map { height: 100%; width: 100%; z-index: 1; transition: filter 0.8s ease; }

/* Time Travel Panel */
.time-travel-panel {
    position: absolute; bottom: 100px; left: 50%; transform: translateX(-50%);
    width: 90%; max-width: 400px; background: var(--glass); backdrop-filter: blur(15px);
    border-radius: 20px; padding: 15px; z-index: 1000; border: 1px solid rgba(255,255,255,0.1);
}

.epoch-labels { display: flex; justify-content: space-between; color: white; font-size: 11px; margin-bottom: 8px; }
.epoch-labels span.active { color: var(--primary); font-weight: bold; }

.epoch-status { text-align: center; color: white; font-size: 12px; margin-top: 5px; opacity: 0.7; }

/* Search UI */
.top-interface { position: absolute; top: 20px; width: 100%; z-index: 1000; display: flex; flex-direction: column; align-items: center; gap: 10px; }
.search-container { width: 90%; max-width: 400px; background: var(--glass); padding: 10px; border-radius: 15px; backdrop-filter: blur(10px); }
input { width: 100%; background: none; border: none; color: white; padding: 8px; border-bottom: 1px solid rgba(255,255,255,0.1); outline: none; }

/* Bottom Nav */
.bottom-nav { position: absolute; bottom: 0; width: 100%; height: 70px; background: var(--glass); backdrop-filter: blur(20px); z-index: 1001; display: flex; justify-content: space-around; align-items: center; border-top: 1px solid rgba(255,255,255,0.1); }
.nav-item { color: white; opacity: 0.5; display: flex; flex-direction: column; align-items: center; font-size: 10px; cursor: pointer; }
.nav-item.active { opacity: 1; color: var(--primary); }
.nav-item i { font-size: 20px; margin-bottom: 4px; }

/* Hist Markers */
.hist-marker { width: 30px; height: 30px; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; animation: float 2s infinite ease-in-out; }
@keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-5px); } }
